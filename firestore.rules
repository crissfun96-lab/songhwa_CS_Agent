rules_version = '2';

// Foxie / Songhwa CS Agent — multi-tenant SaaS.
// All Firestore access is server-side via Firebase Admin SDK (which bypasses
// these rules). This file is a defense-in-depth lockout: if any client SDK
// (browser, mobile) ever connects with a leaked Firebase web key, every read
// and write is rejected.
//
// Deploy:  firebase deploy --only firestore:rules
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
